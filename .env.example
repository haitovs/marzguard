# MarzGuard Configuration
# Copy to .env and fill in values

# Marzban Panel
MARZBAN_BASE_URL=https://panel.example.com:8443
MARZBAN_USERNAME=admin
MARZBAN_PASSWORD=changeme

# MarzGuard Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme_strong_password

# JWT Secret (generate with: openssl rand -hex 32)
JWT_SECRET=change_this_to_a_random_secret_key

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/marzguard.db

# IP Tracking
DEFAULT_IP_LIMIT=2
IP_TTL_SECONDS=300
ENFORCEMENT_INTERVAL=30
REENABLE_CHECK_INTERVAL=60
DEFAULT_REENABLE_DELAY=300

# Telegram Notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Webhook Secret (for Marzban webhooks)
WEBHOOK_SECRET=

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
